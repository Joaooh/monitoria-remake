---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import Navbar from "../components/common/Navbar.jsx";

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}

const {
  title,
  description = "Site oficial da Monitoria de TI do CEUB. Incentivamos pessoas, projetos e ideias.",
  bodyClass = "",
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="var(--purple-primary)" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="preload" href="/fonts/NotoSans-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class={bodyClass}>
    <Navbar client:load transition:persist="navbar" currentPath={currentPath} />
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      sans-serif;
    background-color: #1a1a1a;
    -webkit-font-smoothing: antialiased;
  }

  body.theme-light {
    background-color: #fdfdfd !important;
    color: #1a1a24;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
