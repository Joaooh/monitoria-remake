---
import { Image } from "astro:assets";
import logoCeubLight from "@assets/logo-ceub-light.png";
import FiberBackground from "@components/effects/Fiber.jsx";
import magoRelogio from "@assets/mago/mago-relogio.png";

interface Props {
  titulo: string;
  preTexto: string;
  subTexto: string;
}

const { titulo, preTexto, subTexto } = Astro.props;
---

<section class="oficina-interna-hero">
  <div class="fiber-container">
    <FiberBackground client:load />
    <div class="dark-overlay"></div>
  </div>

  <div class="container">
    <div class="hero-logo-container">
      <Image
        src={logoCeubLight}
        alt="Logo do CEUB"
        class="hero-logo"
        loading="eager"
      />
    </div>

    <div class="hero-content">
      <div class="text-column">
        <h2 class="pre-title">{preTexto}</h2>
        <h1 class="title">{titulo}</h1>
        <p class="subtitle">{subTexto}</p>
      </div>

      <div class="image-column">
        <Image
          src={magoRelogio}
          alt="Mago da monitoria apontando para um relógio"
          class="mago-vertical-img"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .oficina-interna-hero {
    position: relative;
    padding: 60px 2rem 0 2rem;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    overflow: hidden;
    background-color: var(--bg-dark, #0d041a);
    min-height: 40vh;
    border-bottom: 4px solid #7a1a8f;
  }

  .fiber-container {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .dark-overlay {
    position: absolute;
    inset: 0;
    background: rgba(13, 4, 26, 0.4);
  }

  .container {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    width: 100%;
    height: 100%;
  }

  .hero-logo-container {
    position: absolute;
    top: -26px;
    left: 0;
    z-index: 10;
  }

  .hero-logo {
    width: 100px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.3));
  }

  .hero-content {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    width: 100%;
    margin-top: 40px;
  }

  .text-column {
    flex: 0 0 55%;
    padding-bottom: 50px;
  }

  .pre-title {
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    font-weight: 400;
    margin: 0;
    color: rgba(255, 255, 255, 0.8);
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .title {
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 800;
    margin: 0.5rem 0 1.5rem 0;
    color: #ffffff;
    letter-spacing: -1.5px;
    line-height: 1.1;
  }

  .subtitle {
    font-size: clamp(1rem, 1.5vw, 1.1rem);
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
    margin: 0;
  }

  .image-column {
    flex: 0 0 45%;
    display: flex;
    justify-content: center;
    margin-bottom: -4px;
  }

  .mago-vertical-img {
    width: auto;
    max-height: 380px;
    object-fit: contain;
    object-position: bottom center;
    filter: drop-shadow(0 -5px 25px rgba(0, 0, 0, 0.4));
  }

  /* --- RESPONSIVIDADE MOBILE --- */
  @media (max-width: 992px) {
    .hero-logo-container {
      display: none;
    }

    .oficina-interna-hero {
      padding-top: 40px;
      padding-bottom: 0;
    }

    .hero-content {
      flex-direction: column;
      align-items: center;
      text-align: center;
      margin-top: 20px;
    }

    .text-column {
      flex: 1;
      padding-bottom: 20px;
    }

    .title {
      margin-left: 0;
    }

    .image-column {
      flex: 1;
      width: 100%;
      margin-bottom: -4px;
    }

    .mago-vertical-img {
      max-height: 280px;
    }
  }
</style>
