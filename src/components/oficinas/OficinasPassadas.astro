---
import { Image } from "astro:assets";
import { oficinasPassadasData } from "@data/oficinas-passadas.js";
---

<section class="oficinas-passadas-section" id="oficinas-passadas">
  <div class="container">
    <div class="section-header">
      <span class="tag">Histórico</span>
      <h2>Oficinas Passadas <br /> Campus Asa Norte</h2>
      <div class="divider"></div>
    </div>

    <div class="carousel-wrapper">
      <button class="carousel-btn prev" aria-label="Oficinas anteriores">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="15 18 9 12 15 6"></polyline></svg
        >
      </button>

      <div class="carousel-track" id="passadas-track">
        {
          oficinasPassadasData.map((oficina) => (
            <article class="card-passada">
              <div class="card-image-wrapper">
                <Image
                  src={oficina.imagem}
                  alt={oficina.alt}
                  class="card-image"
                  quality="max"
                />
              </div>

              <div class="card-content">
                <h3>{oficina.titulo}</h3>

                <div class="info-horario">
                  {oficina.turmas.map((turma) => (
                    <div class="info-item">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <rect
                          x="3"
                          y="4"
                          width="18"
                          height="18"
                          rx="2"
                          ry="2"
                        />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                      </svg>
                      <span>{turma}</span>
                    </div>
                  ))}
                </div>

                <a
                  href="#"
                  class="btn-inscrever"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Clique para saber mais
                </a>
              </div>
            </article>
          ))
        }
      </div>

      <button class="carousel-btn next" aria-label="Próximas oficinas">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </button>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const track = document.getElementById("passadas-track");
    const btnPrev = document.querySelector(".carousel-btn.prev");
    const btnNext = document.querySelector(".carousel-btn.next");

    if (!track || !btnPrev || !btnNext) return;

    const scrollAmount = 340 + 24;

    const updateButtonVisibility = () => {
      const isAtStart = track.scrollLeft <= 5;
      const isAtEnd =
        track.scrollLeft + track.clientWidth >= track.scrollWidth - 5;

      btnPrev.style.opacity = isAtStart ? "0" : "1";
      btnPrev.style.pointerEvents = isAtStart ? "none" : "all";

      btnNext.style.opacity = isAtEnd ? "0" : "1";
      btnNext.style.pointerEvents = isAtEnd ? "none" : "all";
    };

    btnPrev.addEventListener("click", () => {
      track.scrollBy({ left: -scrollAmount, behavior: "smooth" });
    });

    btnNext.addEventListener("click", () => {
      track.scrollBy({ left: scrollAmount, behavior: "smooth" });
    });

    track.addEventListener("scroll", updateButtonVisibility);
    window.addEventListener("resize", updateButtonVisibility);

    setTimeout(updateButtonVisibility, 100);
  });
</script>

<style>
  .oficinas-passadas-section {
    background-color: #fafafa;
    padding: 40px 2rem;
    position: relative;
    z-index: 10;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tag {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(122, 26, 143, 0.1);
    color: #7a1a8f;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1rem;
    border: 1px solid rgba(122, 26, 143, 0.2);
  }

  h2 {
    font-size: clamp(2rem, 4vw, 2.5rem);
    color: #333333;
    margin-bottom: 1rem;
    font-weight: 700;
    letter-spacing: -1px;
  }

  .divider {
    width: 60px;
    height: 3px;
    background-color: #662c92;
    border-radius: 2px;
  }

  .carousel-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .carousel-track {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding: 0 4px 30px 4px;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
    background: #662c92;
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 10px rgba(102, 44, 146, 0.3);
    color: #ffffff;
    transition: all 0.3s ease;
  }

  .carousel-btn:hover {
    background: #4a148c;
    transform: translateY(-50%) scale(1.05);
    box-shadow: 0 6px 15px rgba(74, 20, 140, 0.4);
    color: #ffffff;
  }

  .carousel-btn svg {
    width: 24px;
    height: 24px;
  }

  .carousel-btn.prev {
    left: -60px;
  }

  .carousel-btn.next {
    right: -60px;
  }

  .card-passada {
    flex: 0 0 340px;
    scroll-snap-align: start;
    background: #ffffff;
    border: 1px solid #f0f0f0;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s;
  }

  .card-passada:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
  }

  .card-image-wrapper {
    width: 100%;
    height: 185px;
    background: #f5f5f5;
    position: relative;
    overflow: hidden;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .card-passada:hover .card-image {
    transform: scale(1.05);
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-content h3 {
    color: #333;
    font-size: 1.15rem;
    margin-bottom: 1rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .info-horario {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    margin-top: auto;
  }

  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    color: #666;
    font-size: 0.85rem;
    line-height: 1.4;
  }

  .info-item svg {
    color: #999;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .btn-inscrever {
    display: block;
    width: 100%;
    padding: 10px 0;
    background: transparent;
    border: 1px solid #662c92;
    color: #662c92;
    text-align: center;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    font-size: 0.9rem;
  }

  .btn-inscrever:hover {
    background: #662c92;
    color: #ffffff;
  }

  @media (max-width: 768px) {
    .oficinas-passadas-section {
      padding: 60px 1.5rem;
    }

    .carousel-btn {
      display: none;
    }

    .carousel-track {
      gap: 16px;
    }

    .card-passada {
      flex: 0 0 280px;
    }
  }
</style>
