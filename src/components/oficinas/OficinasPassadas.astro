---
import { Image } from "astro:assets";
import { oficinasPassadasData } from "@data/oficinas-passadas.js";
---

<section class="oficinas-passadas-section" id="oficinas-passadas">
  <div class="container">
    <div class="section-header">
      <span class="tag">Histórico</span>
      <h2>Oficinas Passadas <br /> Campus Asa Norte</h2>
      <div class="divider"></div>
    </div>

    <div class="carousel-wrapper">
      <button class="carousel-btn prev" aria-label="Oficinas anteriores">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="15 18 9 12 15 6"></polyline></svg
        >
      </button>

      <div class="carousel-track" id="passadas-track">
        {
          oficinasPassadasData.map((oficina) => (
            <article class="card-passada">
              <div class="card-image-wrapper">
                <Image
                  src={oficina.imagem}
                  alt={oficina.alt}
                  class="card-image"
                  quality="max"
                />
              </div>

              <div class="card-content">
                <h3>{oficina.titulo}</h3>

                <div class="info-horario">
                  {oficina.turmas.map((turma) => (
                    <div class="info-item">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <rect
                          x="3"
                          y="4"
                          width="18"
                          height="18"
                          rx="2"
                          ry="2"
                        />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                      </svg>
                      <span>{turma}</span>
                    </div>
                  ))}
                </div>

                <a href={oficina.linkInscricao} class="btn-inscrever">
                  Clique para saber mais
                </a>
              </div>
            </article>
          ))
        }
      </div>

      <button class="carousel-btn next" aria-label="Próximas oficinas">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </button>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const track = document.getElementById("passadas-track");
    const btnPrev = document.querySelector(".carousel-btn.prev");
    const btnNext = document.querySelector(".carousel-btn.next");
    const cards = Array.from(document.querySelectorAll(".card-passada"));

    if (!track || !btnPrev || !btnNext || cards.length === 0) return;

    let currentPage = 0;
    let itemsPerPage = 3;

    const renderPage = () => {
      // Define a quantidade de cards por página baseado no tamanho da tela
      if (window.innerWidth >= 1024) {
        itemsPerPage = 3;
      } else if (window.innerWidth >= 768) {
        itemsPerPage = 2;
      } else {
        itemsPerPage = 1;
      }

      const totalPages = Math.ceil(cards.length / itemsPerPage);

      if (currentPage >= totalPages) currentPage = totalPages - 1;
      if (currentPage < 0) currentPage = 0;

      // Atualiza a opacidade dos botões se não tiver mais páginas pra avançar/voltar
      btnPrev.style.opacity = currentPage === 0 ? "0.3" : "1";
      btnPrev.style.pointerEvents = currentPage === 0 ? "none" : "all";

      btnNext.style.opacity = currentPage >= totalPages - 1 ? "0.3" : "1";
      btnNext.style.pointerEvents =
        currentPage >= totalPages - 1 ? "none" : "all";

      // Esconde todos os cards
      cards.forEach((card) => {
        card.classList.remove("active");
        card.style.display = "none";
      });

      // Calcula os cards da página atual e mostra com animação
      const startIndex = currentPage * itemsPerPage;
      const endIndex = startIndex + itemsPerPage;
      const currentCards = cards.slice(startIndex, endIndex);

      currentCards.forEach((card, index) => {
        card.style.display = "flex";
        void card.offsetWidth;
        // Efeito de delay na animação
        card.style.animationDelay = `${index * 0.08}s`;
        card.classList.add("active");
      });
    };

    btnPrev.addEventListener("click", () => {
      if (currentPage > 0) {
        currentPage--;
        renderPage();
      }
    });

    btnNext.addEventListener("click", () => {
      const totalPages = Math.ceil(cards.length / itemsPerPage);
      if (currentPage < totalPages - 1) {
        currentPage++;
        renderPage();
      }
    });

    let resizeTimer;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(renderPage, 200);
    });

    renderPage();
  });
</script>

<style>
  .oficinas-passadas-section {
    background-color: #fafafa;
    padding: 40px 2rem;
    position: relative;
    z-index: 10;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tag {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(122, 26, 143, 0.1);
    color: #7a1a8f;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1rem;
    border: 1px solid rgba(122, 26, 143, 0.2);
  }

  h2 {
    font-size: clamp(2rem, 4vw, 2.5rem);
    color: var(--text-dark);
    margin-bottom: 1rem;
    font-weight: 700;
    letter-spacing: -1px;
  }

  .divider {
    width: 60px;
    height: 3px;
    background-color: var(--purple-primary);
    border-radius: 2px;
  }

  .carousel-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel-track {
    display: flex;
    gap: 24px;
    justify-content: center;
    width: 100%;
    min-height: 440px;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
    background: var(--purple-primary);
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 10px rgba(102, 44, 146, 0.3);
    color: #ffffff;
    transition: all 0.3s ease;
  }

  .carousel-btn:hover {
    background: #4a148c;
    transform: translateY(-50%) scale(1.05);
    box-shadow: 0 6px 15px rgba(74, 20, 140, 0.4);
    color: #ffffff;
  }

  .carousel-btn svg {
    width: 24px;
    height: 24px;
  }

  .carousel-btn.prev {
    left: -60px;
  }

  .carousel-btn.next {
    right: -60px;
  }

  .card-passada {
    flex: 0 0 340px;
    display: none;
    opacity: 0;
    background: #ffffff;
    border: 1px solid #f0f0f0;
    border-radius: 12px;
    overflow: hidden;
    flex-direction: column;
    transition:
      transform 0.3s,
      box-shadow 0.3s;
  }

  .card-passada.active {
    display: flex;
    animation: fadeInPage 0.4s ease-out forwards;
  }

  @keyframes fadeInPage {
    0% {
      opacity: 0;
      transform: scale(0.96) translateY(10px);
    }
    100% {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  .card-passada.active:hover {
    transform: translateY(-4px) !important;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
  }

  .card-image-wrapper {
    width: 100%;
    height: 185px;
    background: var(--bg-light);
    position: relative;
    overflow: hidden;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .card-passada:hover .card-image {
    transform: scale(1.05);
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-content h3 {
    color: #333;
    font-size: 1.15rem;
    margin-bottom: 1rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .info-horario {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    margin-top: auto;
  }

  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    color: #666;
    font-size: 0.85rem;
    line-height: 1.4;
  }

  .info-item svg {
    color: #999;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .btn-inscrever {
    display: block;
    width: 100%;
    padding: 10px 0;
    background: transparent;
    border: 1px solid var(--purple-primary);
    color: var(--purple-primary);
    text-align: center;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    font-size: 0.9rem;
  }

  .btn-inscrever:hover {
    background: var(--purple-primary);
    color: #ffffff;
  }

  @media (max-width: 768px) {
    .oficinas-passadas-section {
      padding: 60px 1.5rem;
    }

    .card-passada {
      flex: 0 0 100%;
      max-width: 340px;
    }

    .carousel-wrapper {
      padding-bottom: 60px;
    }

    .carousel-btn {
      top: auto;
      bottom: 0;
      transform: none;
    }

    .carousel-btn:hover {
      transform: scale(1.05);
    }

    .carousel-btn.prev {
      left: calc(50% - 60px);
    }

    .carousel-btn.next {
      right: calc(50% - 60px);
    }
  }
</style>
