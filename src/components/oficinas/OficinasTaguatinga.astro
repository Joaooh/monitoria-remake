---
import { Image } from "astro:assets";
import imgMagosTrabalhando from "@assets/mago/oficinas/magos-trabalhando.png";

const placeholders = [1, 2, 3];
---

<section class="taguatinga-section ativas" id="taguatinga-ativas">
  <div class="container">
    <div class="section-header">
      <h2>Oficinas Disponíveis <br /> Campus Taguatinga</h2>
      <div class="divider"></div>
    </div>

    <div class="cards-grid">
      {
        placeholders.map(() => (
          <article class="card-placeholder">
            <div class="card-image-wrapper">
              <Image
                src={imgMagosTrabalhando}
                alt="Magos trabalhando"
                class="card-image"
                quality="max"
              />
            </div>
            <div class="card-content">
              <button class="btn-em-breve" disabled>
                Em breve
              </button>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<section class="taguatinga-section passadas" id="taguatinga-passadas">
  <div class="container">
    <div class="section-header">
      <h2>Oficinas Passadas <br /> Campus Taguatinga</h2>
      <div class="divider"></div>
    </div>

    <div class="cards-grid">
      {
        placeholders.map(() => (
          <article class="card-placeholder">
            <div class="card-image-wrapper">
              <Image
                src={imgMagosTrabalhando}
                alt="Magos trabalhando nas futuras oficinas de Taguatinga"
                class="card-image"
                quality="max"
              />
            </div>
            <div class="card-content">
              <button class="btn-em-breve-fantasma" disabled>
                Em breve
              </button>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .taguatinga-section {
    padding: 80px 2rem;
    position: relative;
    z-index: 10;
  }

  .taguatinga-section.ativas {
    background-color: #ffffff;
  }

  .taguatinga-section.passadas {
    background-color: #fafafa;
    padding-bottom: 100px;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  h2 {
    font-size: clamp(1.8rem, 3vw, 2.2rem);
    color: var(--text-dark);
    margin-bottom: 1rem;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .divider {
    width: 60px;
    height: 3px;
    background-color: var(--purple-primary);
    border-radius: 2px;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
    justify-content: center;
    max-width: 1000px;
    margin: 0 auto;
  }

  .card-placeholder {
    background: #ddd1ff;
    border: none;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
  }

  .card-image-wrapper {
    width: 100%;
    aspect-ratio: 4 / 3;
    position: relative;
    overflow: hidden;
    background: #a9d6ff;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-content {
    padding: 1.2rem;
    display: flex;
    justify-content: center;
  }

  .btn-em-breve {
    width: 100%;
    padding: 10px 0;
    background: var(--purple-primary);
    border: none;
    color: #ffffff;
    text-align: center;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: not-allowed;
    opacity: 0.8;
  }

  .btn-em-breve-fantasma {
    display: block;
    width: 100%;
    padding: 10px 0;
    background: transparent;
    border: 1px solid var(--purple-primary);
    color: var(--purple-primary);
    text-align: center;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: not-allowed;
    transition: all 0.3s ease;
  }

  /* .btn-em-breve-fantasma:hover {
    background: var(--purple-primary);
    color: #ffffff;
  } */

  /* --- RESPONSIVIDADE MOBILE --- */
  @media (max-width: 600px) {
    .taguatinga-section {
      padding: 60px 1.5rem;
    }

    .taguatinga-section.passadas {
      padding-bottom: 80px;
    }

    .cards-grid {
      grid-template-columns: 1fr;
    }

    .card-placeholder:nth-child(n + 2) {
      display: none;
    }
  }
</style>
