---
import { Image } from "astro:assets";

import imgOficinas from "../../assets/mago/mago-oficina.png";
import imgProjetos from "../../assets/mago/mago-acidentando.png";
import imgApoio from "../../assets/mago/mago-working.png";

const iniciativas = [
  {
    title: "Oficinas",
    description:
      "Descubra o que ensinamos em nossas oficinas práticas e desenvolva novas habilidades.",
    image: imgOficinas,
    alt: "Mago dando aula em um quadro verde",
  },
  {
    title: "Projetos",
    description:
      "Conheça as ideias e soluções tecnológicas que construímos em conjunto.",
    image: imgProjetos,
    alt: "Mago se acidentando/trabalhando em projetos",
  },
  {
    title: "Apoio Acadêmico",
    description:
      "Saiba como nossa equipe pode te ajudar a superar os desafios das disciplinas.",
    image: imgApoio,
    alt: "Mago trabalhando focado em uma mesa de escritório",
  },
];
---

<section
  class="iniciativas-section"
  id="iniciativas"
  aria-labelledby="iniciativas-title"
>
  <div class="container">
    <div class="section-header">
      <span class="tag">Nossas Frentes</span>
      <h2 id="iniciativas-title">O que nós fazemos</h2>
      <p class="subtitle">
        Conheça as principais iniciativas da monitoria para impulsionar o seu
        aprendizado.
      </p>
    </div>

    <div class="cards-grid">
      {
        iniciativas.map((item) => (
          <article class="card">
            <div class="card-image-wrapper">
              <Image
                src={item.image}
                alt={item.alt}
                class="card-image"
                quality="max"
              />
            </div>
            <div class="card-content">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .iniciativas-section {
    background: linear-gradient(to bottom, var(--bg-dark), #160824);
    padding: 100px 2rem 50px 2rem;
    position: relative;
    z-index: 10;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tag {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(210, 168, 255, 0.1);
    color: var(--purple-neon);
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1rem;
    border: 1px solid rgba(210, 168, 255, 0.2);
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--text-main);
    margin-bottom: 1rem;
    font-weight: 700;
    letter-spacing: -1px;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.1rem;
    max-width: 600px;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .card {
    background: rgba(102, 44, 146, 0.15);
    border: 1px solid rgba(210, 168, 255, 0.12);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .card:hover {
    transform: translateY(-8px);
    border-color: rgba(210, 168, 255, 0.5);
    box-shadow:
      0 15px 30px rgba(0, 0, 0, 0.4),
      0 0 25px rgba(102, 44, 146, 0.3);
  }

  .card-image-wrapper {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #1a1a1a;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .card:hover .card-image {
    transform: scale(1.03);
  }

  .card-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-content h3 {
    color: var(--text-main);
    font-size: 1.5rem;
    margin-bottom: 0.8rem;
    font-weight: 600;
  }

  .card-content p {
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* --- RESPONSIVIDADE MOBILE --- */
  @media (max-width: 900px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .iniciativas-section {
      padding: 60px 1.5rem;
    }
    .cards-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
