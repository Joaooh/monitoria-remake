---
import FiberBackground from "../effects/Fiber.jsx";
import TextType from "../effects/Typewriter.jsx";

import { Image } from "astro:assets";
import magoImg from "../../assets/mago/mago-padrao.png";
import logoCeub from "../../assets/logo-ceub-light.png";
---

<section class="hero" aria-label="Seção de boas-vindas">
  <FiberBackground client:idle />

  <div class="hero-fade" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="hero-logo-container">
      <Image
        src={logoCeub}
        alt="Logo do Centro Universitário de Brasília - CEUB"
        class="hero-logo"
        loading="eager"
      />
    </div>

    <main class="main-layout" role="main">
      <div class="text-section">
        <h1 class="hero-title">
          <span class="line">Mais que oficinas.</span>
          <span class="line typewriter-container">
            <span class="incentivamos-text">Incentivamos{" "}</span>

            <span aria-hidden="true" class="typewriter-animated">
              <TextType
                client:load
                text={["pessoas.", "projetos.", "ideias.", "talentos."]}
                typingSpeed={80}
                deletingSpeed={40}
                pauseDuration={2000}
                textColors={["var(--purple-neon)"]}
              />
            </span>

            <span class="sr-only">pessoas, projetos, ideias e talentos.</span>
          </span>
        </h1>

        <div class="buttons">
          <a href="#iniciativas" class="btn primary">Conhecer projeto</a>
          <a href="/oficinas" class="btn secondary">Ver oficinas</a>
        </div>
      </div>

      <div class="image-section" aria-hidden="true">
        <Image
          src={magoImg}
          alt="Mago da monitoria com cajado brilhante em estilo cartoon"
          class="mago-img"
          loading="eager"
          decoding="async"
        />
      </div>
    </main>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    width: 100vw;
    overflow: hidden;
    background-color: var(--bg-dark);
  }

  .hero-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 35vh;
    background: linear-gradient(to bottom, transparent 0%, var(--bg-dark) 100%);
    z-index: 1;
    pointer-events: none;
  }

  .hero-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    width: 100%;
    height: 100%;
    color: var(--text-main);
  }

  .hero-logo-container {
    width: 100%;
    z-index: 10;
  }

  .hero-logo {
    width: 105px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.3));
  }

  .main-layout {
    display: flex;
    align-items: center;
    flex: 1;
    position: relative;
    width: 100%;
  }

  .text-section {
    width: 60%;
    z-index: 10;
    transform: translateY(-2rem);
  }

  h1.hero-title {
    font-size: clamp(2.5rem, 4vw, 4rem);
    line-height: 1.2;
    margin-bottom: 2rem;
    font-weight: 600;
    text-shadow: 0px 4px 12px rgba(0, 0, 0, 0.4);
  }

  .hero-title .line {
    display: block;
    white-space: nowrap;
  }

  .typewriter-container {
    display: inline-flex;
    min-width: 300px;
  }

  .buttons {
    display: flex;
    gap: 1rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    line-height: 1.2;
    text-decoration: none;
    padding: 0.8rem 1.5rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: bold;
    cursor: pointer;
    transition: 0.2s;
    border: none;
    min-width: 140px;
  }

  .btn:focus-visible {
    outline: 3px solid var(--purple-neon);
    outline-offset: 2px;
  }

  .btn.primary {
    background-color: var(--purple-neon);
    color: #1a1a1a;
  }

  .btn.primary:hover {
    background-color: var(--purple-hover);
  }

  .btn.secondary {
    background-color: transparent;
    color: var(--text-main);
    border: 2px solid rgba(255, 255, 255, 0.5);
  }

  .btn.secondary:hover {
    border-color: var(--text-main);
    background: rgba(255, 255, 255, 0.1);
  }

  .image-section {
    position: absolute;
    right: -10rem;
    bottom: 0rem;
    height: 90vh;
    z-index: 5;
    pointer-events: none;
  }

  .mago-img {
    height: 100%;
    max-height: 100%;
    width: auto;
    max-width: none;
    object-fit: contain;
    object-position: bottom right;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.6));
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-20px);
    }
    100% {
      transform: translateY(0px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mago-img {
      animation: none;
    }
  }

  /* --- RESPONSIVIDADE MOBILE --- */
  @media (max-width: 768px) {
    .hero-logo-container {
      display: none;
    }

    .btn {
      padding: 0.9rem 1.45rem;
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: bold;
      cursor: pointer;
      transition: 0.2s;
      border: none;
    }

    .main-layout {
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding-top: 0;
      padding-bottom: 0;
    }

    .image-section {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -62%);
      width: 105vw;
      height: 60vh;
      z-index: 1;
      pointer-events: none;
    }

    .mago-img {
      height: 100%;
      width: 100%;
      max-width: none;
      object-fit: contain;
      object-position: center bottom;
      opacity: 0.9;
      filter: drop-shadow(0 15px 25px rgba(0, 0, 0, 0.6));
    }

    .text-section {
      width: 100%;
      transform: translateY(8.4rem);
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      padding: 0 1.5rem;
      z-index: 10;
      margin-top: 0;
    }

    h1.hero-title {
      font-size: clamp(2.2rem, 7vw, 2.8rem);
      margin-bottom: 0.4rem;
      text-align: left;
      width: 100%;
      text-shadow: 0px 4px 12px rgba(0, 0, 0, 0.8);
    }

    .hero-title .line {
      display: block;
      white-space: nowrap;
    }

    .typewriter-container {
      display: block;
      width: 100%;
    }

    .incentivamos-text {
      display: block;
    }

    .typewriter-animated {
      display: block;
    }

    .buttons {
      width: 100%;
      justify-content: center;
      margin-top: 1rem;
      z-index: 10;
    }
  }
</style>
