---
import { Image } from "astro:assets";

interface Props {
  nome: string;
  descricao: string;
  foto: any;
  isExMembro?: boolean;
  loading?: "eager" | "lazy";
}

const {
  nome,
  descricao,
  foto,
  isExMembro = false,
  loading = "lazy",
} = Astro.props;
---

<article class={`monitor-card ${isExMembro ? "ex-membro-card" : ""}`}>
  <div class={`monitor-foto-wrapper ${isExMembro ? "grayscale" : ""}`}>
    <Image
      src={foto}
      alt={`Foto de ${nome}`}
      class="monitor-foto"
      loading={loading}
    />
  </div>
  <h3>{nome}</h3>
  <p class="descricao" set:html={descricao} />
</article>

<style>
  .monitor-card {
    background: #ffffff;
    border: 1px solid #eaeaea;
    border-radius: 16px;
    padding: 2.5rem 1.5rem;
    text-align: center;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
  }

  .monitor-card:hover {
    border-color: #ddd1ff;
    box-shadow: 0 15px 30px rgba(102, 44, 146, 0.08);
  }

  .ex-membro-card {
    background: #fafafa;
    border-color: #f0f0f0;
  }

  .ex-membro-card:hover {
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
  }

  .monitor-foto-wrapper {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(135deg, #662c92, #e81c61);
    margin-bottom: 1.5rem;
    box-shadow: 0 8px 15px rgba(232, 28, 97, 0.2);
  }

  .monitor-foto-wrapper.grayscale {
    background: linear-gradient(135deg, #999, #ccc);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
  }

  .monitor-foto {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #ffffff;
    background-color: #ffffff;
  }

  .monitor-card h3 {
    color: #3b004d;
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.8rem;
  }

  .monitor-card .descricao {
    color: #555555;
    font-size: 0.95rem;
    line-height: 1.6;
  }
</style>
