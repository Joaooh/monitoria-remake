---
import { Image } from "astro:assets";
import logoCeubLight from "@assets/logo-ceub-light.png";
import FiberBackground from "@components/effects/Fiber.jsx";
import magoSpell from "@assets/mago/mago-spell.png";

interface Props {
  titulo: string;
  preTexto: string;
  subTexto: string;
}

const { titulo, preTexto, subTexto } = Astro.props;
---

<section class="equipe-hero">
  <div class="fiber-container">
    <FiberBackground client:load />
    <div class="dark-overlay"></div>
  </div>

  <div class="container">
    <div class="hero-logo-container">
      <Image
        src={logoCeubLight}
        alt="Logo do CEUB"
        class="hero-logo"
        loading="eager"
      />
    </div>

    <div class="hero-content">
      <div class="text-column">
        <h2 class="pre-title">{preTexto}</h2>
        <h1 class="title">{titulo}</h1>
        <p class="subtitle">{subTexto}</p>
      </div>

      <div class="image-column">
        <div class="image-wrapper-glow">
          <Image
            src={magoSpell}
            alt="Mago da monitoria conjurando um feitiço de luz"
            class="mago-spell-img"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .equipe-hero {
    position: relative;
    padding: 20px 2rem 0 2rem;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    overflow: hidden;
    background-color: var(--bg-dark, #0d041a);
    min-height: 30vh;
    border-bottom: 4px solid #7a1a8f;
  }

  .fiber-container {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .dark-overlay {
    position: absolute;
    inset: 0;
    background: rgba(13, 4, 26, 0.4);
  }

  .container {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    width: 100%;
    height: 100%;
  }

  .hero-logo-container {
    position: absolute;
    top: 14px;
    left: 0;
    width: 100%;
    z-index: 10;
  }

  .hero-logo {
    width: 100px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.3));
  }

  .hero-content {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    width: 100%;
    margin-top: 51px;
    gap: 2rem;
  }

  .text-column {
    flex: 0 0 50%;
    padding-bottom: 50px;
  }

  .pre-title {
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    font-weight: 400;
    margin: 0;
    color: rgba(255, 255, 255, 0.9);
    letter-spacing: -0.5px;
    line-height: 1;
  }

  .title {
    font-size: clamp(4.5rem, 8vw, 7rem);
    font-weight: 800;
    margin: 0 0 1rem 0;
    color: #ffffff;
    letter-spacing: -2px;
    line-height: 1;
    margin-left: -4px;
  }

  .subtitle {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.5;
    margin: 0;
  }

  .image-column {
    flex: 0 0 50%;
    display: flex;
    justify-content: flex-start;
    margin-bottom: -4px;
  }

  .image-wrapper-glow {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .image-wrapper-glow::before {
    content: "";
    position: absolute;
    width: 80%;
    height: 80%;
    background: radial-gradient(
      circle,
      rgba(122, 26, 143, 0.3) 0%,
      rgba(13, 4, 26, 0) 70%
    );
    z-index: -1;
    border-radius: 50%;
  }

  .mago-spell-img {
    width: 100%;
    max-width: 400px;
    height: auto;
    object-fit: contain;
    transform: scaleX(-1);
    filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.5));
    margin-left: -10px;
  }

  /* --- RESPONSIVIDADE MOBILE --- */
  @media (max-width: 992px) {
    .hero-logo-container {
      display: none;
    }

    .equipe-hero {
      padding-top: 40px;
      padding-left: 0;
      padding-right: 0;
      min-height: auto;
    }

    .container {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .hero-content {
      flex-direction: column;
      align-items: center;
      text-align: center;
      margin-top: 60px;
      gap: 1rem;
    }

    .text-column {
      flex: 1;
      padding-bottom: 10px;
      padding-top: 0;
      align-items: center;
    }

    .title {
      margin-left: 0;
    }

    .image-column {
      flex: 1;
      justify-content: center;
      margin-bottom: -4px;
      width: 100vw;
    }

    .mago-spell-img {
      width: 100%;
      max-width: 200px;
      height: auto;
      object-fit: contain;
      object-position: center bottom;
      margin-left: 0;
    }
  }
</style>
