---
import { IconCloud } from "../effects/IconCloud.jsx";

const slugs = [
  "c",
  "cplusplus",
  "rust",
  "go",
  "java",
  "python",
  "javascript",
  "typescript",
  "ruby",
  "php",
  "html5",
  "css",
  "react",
  "astro",
  "nodedotjs",
  "postgresql",
  "docker",
  "amazonaws",
  "nginx",
  "linux",
  "archlinux",
  "git",
  "github",
  "visualstudiocode",
  "figma",
  "androidstudio",
];

const imagesUrl = slugs.map(
  (slug) => `https://cdn.simpleicons.org/${slug}/${slug}`,
);
---

<section class="pitaco-objetivo">
  <div class="container">
    <div class="grid-wrapper">
      <div class="content-column">
        <h2 class="title">QUAL É O NOSSO OBJETIVO?</h2>
        <div class="divider" aria-hidden="true"></div>

        <div class="features-list">
          <div class="feature-item">
            <div class="feature-icon" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
                ></path><circle cx="9" cy="7" r="4"></circle><polyline
                  points="16 11 18 13 22 9"></polyline></svg
              >
            </div>
            <div class="feature-text">
              <h3>Troca de Experiências</h3>
              <p>
                Criamos um ecossistema amigável em que todos compartilham
                vivências, expandindo redes de contato através de interesses
                comuns na tecnologia.
              </p>
            </div>
          </div>

          <div class="feature-item">
            <div class="feature-icon" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polygon
                  points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
                ></polygon></svg
              >
            </div>
            <div class="feature-text">
              <h3>Aprendizado Contínuo</h3>
              <p>
                Aceleramos o crescimento técnico individual e coletivo,
                debatendo tendências ativamente e explorando stacks modernos com
                suporte colaborativo.
              </p>
            </div>
          </div>

          <div class="feature-item">
            <div class="feature-icon" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"
                ></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"
                ></polyline><line x1="12" y1="22.08" x2="12" y2="12"
                ></line></svg
              >
            </div>
            <div class="feature-text">
              <h3>Projetos em Conjunto</h3>
              <p>
                Aplicamos ideias ousadas unindo forças para arquitetar peças
                valiosas de software praticando código e cooperação de ponta a
                ponta.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="cloud-column">
        <IconCloud images={imagesUrl} icons={null} client:visible />
      </div>
    </div>
  </div>
</section>

<style>
  .pitaco-objetivo {
    padding: 90px 2rem 90px 2rem;
    background: var(--bg-light);
  }

  .container {
    max-width: 1250px;
    margin: 0 auto;
  }

  .grid-wrapper {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 5rem;
  }

  .content-column {
    flex: 1.1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  .cloud-column {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 3rem;
  }

  .title {
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    color: var(--pitaco-primary);
    font-weight: 800;
    margin-bottom: 1.5rem;
    letter-spacing: -0.5px;
  }

  .divider {
    width: 60px;
    height: 4px;
    background: linear-gradient(90deg, var(--pitaco-primary), var(--pitaco-accent), var(--pitaco-primary));
    background-size: 200% 100%;
    animation: gradientPanLine 3s ease-in-out infinite;
    border-radius: 2px;
    margin-bottom: 3.5rem;
  }

  @keyframes gradientPanLine {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .features-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .feature-item {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    transition: transform 0.3s ease;
  }

  .feature-item:hover {
    transform: translateX(8px);
  }

  .feature-icon {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: rgba(40, 58, 134, 0.08);
    color: var(--pitaco-primary);
    border: 1px solid rgba(40, 58, 134, 0.1);
  }

  .feature-text h3 {
    color: var(--pitaco-primary);
    font-size: 1.25rem;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    letter-spacing: 0.2px;
  }

  .feature-text p {
    color: var(--text-dark);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
  }

  /* --- RESPONSIVIDADE MOBILE --- */
  @media (max-width: 992px) {
    .grid-wrapper {
      flex-direction: column;
      gap: 3rem;
    }

    .cloud-column {
      width: 100%;
      margin-top: -3rem;
      margin-bottom: -3rem;
    }

    .pitaco-objetivo {
      padding-bottom: 100px;
    }
  }
</style>
